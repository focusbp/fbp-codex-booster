<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
body { margin: 0; font-family: system-ui, sans-serif; color: #1f2933; background: #f7f7f4; }
a { color: inherit; }
.mall-header, .mall-footer { background: #ffffff; border-bottom: 1px solid #d9ded7; }
.mall-footer { border-top: 1px solid #d9ded7; border-bottom: 0; }
.mall-shell { width: min(1040px, calc(100% - 32px)); margin: 0 auto; }
.mall-nav { display: flex; align-items: center; justify-content: space-between; gap: 16px; min-height: 56px; }
.mall-nav-links { display: flex; gap: 14px; font-size: 14px; }
.mall-main { padding: 24px 0 40px; }
.mall-title { font-size: 24px; margin: 0 0 18px; }
.mall-card { background: #ffffff; border: 1px solid #d9ded7; border-radius: 8px; padding: 16px; }
.mall-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 14px; }
.mall-form { display: grid; gap: 12px; max-width: 520px; }
.mall-label { display: grid; gap: 6px; font-size: 14px; }
.mall-input, .mall-select { box-sizing: border-box; width: 100%; padding: 10px; border: 1px solid #b8c0b5; border-radius: 6px; background: #ffffff; }
.mall-button { display: inline-flex; align-items: center; justify-content: center; min-height: 40px; padding: 0 14px; border: 0; border-radius: 6px; background: #256b5f; color: #ffffff; text-decoration: none; cursor: pointer; }
.mall-button-subtle { background: #eef2ed; color: #1f2933; }
.mall-table { width: 100%; border-collapse: collapse; background: #ffffff; }
.mall-table th, .mall-table td { padding: 10px; border-bottom: 1px solid #d9ded7; text-align: left; }
.mall-total { display: grid; justify-content: end; gap: 6px; margin-top: 16px; }
</style>
